# Database connection string
DATABASE_URL=postgresql://username:password@localhost:5432/bank_loan_db

# JWT secret key
JWT_SECRET=your_jwt_secret_key_here

# Allowed frontend origins for CORS (comma-separated). Leave empty to allow all origins.
# Example: CORS_ORIGIN=http://localhost:3000,https://your-frontend-domain.com
CORS_ORIGIN=http://localhost:3000

# Server port
PORT=5000
